# === 己→坤2宫（戌刑未）===
jixing_ji_gong=2
jixing_ji_xing=戌刑未
jixing_ji_wuxing=土

# 路径1：暗合（来源：参考文档）
jixing_ji_path1_method=暗合
jixing_ji_path1_target=甲
jixing_ji_path1_problem=甲己合，但甲入坤宫为绝地且入墓，引入甲象反受刑伤
jixing_ji_path1_viable=false
jixing_ji_path1_source=参考文档

# 路径2：地支合化（来源：参考文档）
