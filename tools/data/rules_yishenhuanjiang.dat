# rules_yishenhuanjiang.dat — 移神换将化解规则
# 来源标注：bmhq=笔记 参考文档=yishenhuanjiang.txt （推导）=通用原则推演
# ═══════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────
# Section 1: 三方法体系（来源：bmhq L211-214）
# ───────────────────────────────────────────────────────────────────
method_1_name=灭象
method_1_desc=在一个方位除掉对应的形象，移走后不要再碰，三月起效
method_1_scope=单方位
method_1_risk=低
method_1_source=bmhq L211-212

method_2_name=布阵
method_2_desc=在多方位放置对应的形象或行为，以天干为主，门星神也可以布，压制
method_2_scope=多方位
method_2_risk=中
method_2_source=bmhq L213

method_3_name=换局
method_3_desc=整个局换成另一个更好的局，移星换斗寻时借运
method_3_scope=全局
method_3_risk=高
method_3_source=bmhq L214

# 压阵形象四载体（来源：bmhq L250）
carrier_types=文字,物体,意识,行为
carrier_source=bmhq L250

# ───────────────────────────────────────────────────────────────────
# Section 2: 化解四步骤
# ───────────────────────────────────────────────────────────────────
step_1_name=灭象
step_1_desc=移除凶象物品或形象，只灭能灭的象，不能移动的不动
step_1_source=bmhq L212

step_2_name=移走
step_2_desc=将凶象转移至不影响的位置或方位
step_2_source=bmhq L212

step_3_name=补象
step_3_desc=放置吉象物品，缺什么补什么
step_3_source=bmhq L292

step_4_name=引动
step_4_desc=通过行为激活化解物品的能量场
step_4_source=参考文档

