yindong_1_desc=响铃、乐器
yindong_1_source=参考文档 L869

yindong_2_name=光引
yindong_2_desc=亮灯、焚香、反光镜
yindong_2_source=参考文档 L871

yindong_3_name=气引
yindong_3_desc=通风、开窗
yindong_3_source=参考文档 L873

yindong_4_name=择时
yindong_4_desc=必须在真太阳时的对应时辰执行
yindong_4_source=参考文档 L873

yindong_count=4

# ───────────────────────────────────────────────────────────────────
