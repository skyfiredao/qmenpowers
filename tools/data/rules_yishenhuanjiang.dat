jixing_ji_path2_target=卯合戌
jixing_ji_path2_action=补卯象合住戌（己带戌(甲戌己)，卯戌合锁住刑源）
jixing_ji_path2_lookup=dizhi:卯
jixing_ji_path2_viable=true
jixing_ji_path2_source=参考文档+推导
jixing_ji_path3_method=地支合
jixing_ji_path3_target=午合未
jixing_ji_path3_action=补午象合住未（坤宫含未，午未合锁住被刑方）
jixing_ji_path3_lookup=dizhi:午
jixing_ji_path3_viable=true
jixing_ji_path3_source=推导

# 路径3：泄化（来源：参考文档）
