# ───────────────────────────────────────────────────────────────────
# Section 9: 禁忌规则
# ───────────────────────────────────────────────────────────────────
# 参考文档L876-904原文四大禁忌 + bmhq L212两条
jinji_1=填实禁忌：在宫位逢空亡且带击刑/凶格时，绝对禁止使用大质量、实心、沉重的物品进行硬填
jinji_1_source=参考文档 L878-881

jinji_2=冲突禁忌：化解物的地支象意绝对不能与该宫位地支相冲
jinji_2_source=参考文档 L883-887

jinji_3=贪多禁忌：一个宫位内放置过多属性混杂的化解物
jinji_3_source=参考文档 L889-891

jinji_4=时间错位禁忌：不校对真太阳时，或在日全食、月全食、雷电交加等极端天气下实施
jinji_4_source=参考文档 L893-896

jinji_5=只灭能灭的象，不能移动的不动
jinji_5_source=bmhq L212

jinji_6=移动后不要再碰，不要再拿回原位直到问题解决
jinji_6_source=bmhq L212

jinji_count=9

jinji_7=贪合忘生禁忌：入墓宫位慎用合法——合会进一步束缚能量加重入墓，优先用生和泄
jinji_7_source=yishenhuanjiang-patch

jinji_8=材质纯度禁忌：泄法用金必须真材实料（铜、钢、铝），电镀塑料无效
jinji_8_source=yishenhuanjiang-patch

jinji_9=动静结合禁忌：泄法物应能动（铃铛偶尔响），合法物应静（红卡安放不动）
jinji_9_source=yishenhuanjiang-patch

# ───────────────────────────────────────────────────────────────────
# Section 9b: 时间规则
# ───────────────────────────────────────────────────────────────────
timing_general=用则为信，三月起效，前提和环境发生重大变化时结束
timing_general_source=bmhq L212
# timing_hefa 仅适用于婚恋场景（丁壬合等），不用于一般化解
# timing_hefa=合法需在各自方位放满9天（9天合象，代表天干本身），再将两物放到一起
# timing_hefa_source=bmhq L413
timing_keying=摆放后的3-7天内，留意克应信号
timing_keying_source=参考文档 L799

# ───────────────────────────────────────────────────────────────────
# Section 10: 引动方式
