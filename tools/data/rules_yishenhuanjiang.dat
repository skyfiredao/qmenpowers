# Section 21: 灭象必须原则（来源：bmhq L221）
# ───────────────────────────────────────────────────────────────────
miexiang_mandatory_principle=天干的刑，墓，庚。明显直接的严重损害，最危险，必须灭象。
miexiang_mandatory_principle_source=bmhq L221

