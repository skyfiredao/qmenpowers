任职_role_yiren=ref:日干
任职_judge_01=yiren?旺+yiren?奇+yiren?吉格+guanzhang>yiren=>日干旺相得奇吉格开门来生,必得重用
任职_judge_02=guanzhang>yiren=>开门生日干,上官看重
任职_judge_03=guanzhang!yiren=>开门克日干,任职不利
任职_judge_04=guanzhang=yiren=>比和,平常差遣
任职_judge_05=yiren?囚=>日干休囚,任职辛苦无益

# --- 退役 (卷七) ---
# 以开门为官长,日干为退役人
退役_label=退役
退役_source=卷七
退役_role_guanzhang=gate:开门
退役_role_tuiren=ref:日干
退役_judge_01=guanzhang=tuiren=>开门比和日干,官有眷恋不准退
退役_judge_02=guanzhang!tuiren=>开门克日干,准退但有怒责
退役_judge_03=guanzhang>tuiren=>开门生日干,官挽留不舍
退役_judge_04=tuiren!guanzhang=>日干克开门,必退
退役_judge_05=tuiren?空=>日干空亡,退而无碍

# --- 迁移 (卷七) ---
# 以九星九宫分方,三奇吉门者可迁
迁移_label=迁移
迁移_source=卷七
迁移_role_rigan=ref:日干
迁移_role_shigan=ref:时干
迁移_judge_01=shigan?奇+shigan?吉门=>所往方得三奇吉门,迁移大吉
迁移_judge_02=shigan?吉门=>所往方得吉门,迁移可行
迁移_judge_03=shigan?凶门+shigan?凶格=>所往方凶门凶格,不宜迁移
迁移_judge_04=shigan?空=>所往方空亡,迁后不安
迁移_judge_05=rigan?旺+shigan>rigan=>我旺相彼来生,迁移有益
迁移_judge_06=shigan!rigan=>所往方克我,迁后不利

# --- 行人安否 (卷七) ---
# 以行人年命日干决之(此处用时干代表行人)
行人安否_label=行人安否
行人安否_source=卷七
行人安否_role_xingren=ref:时干
行人安否_judge_01=xingren?旺+xingren?吉格=>行人旺相得吉格,在外名利遂心
行人安否_judge_02=xingren?旺=>行人旺相,在外平安
行人安否_judge_03=xingren?囚=>行人休囚,在外不如意非病即困
行人安否_judge_04=xingren?墓=>行人入墓,其人恐不在世
行人安否_judge_05=xingren?空=>行人空亡,音信全无恐有不测
行人安否_judge_06=xingren?内=>行人在内四宫,距离近
行人安否_judge_07=xingren?外=>行人在外四宫,距离远

# --- 行人归期 (卷七) ---
# 以庚为阻隔,庚加年干为年格年内归
行人归期_label=行人归期
行人归期_source=卷七
行人归期_role_xingren=ref:时干
行人归期_role_jiaren=ref:日干
行人归期_judge_01=庚格:时=>时格,时辰内可归
行人归期_judge_02=庚格:日=>日格,当日可归
行人归期_judge_03=庚格:月=>月格,当月可归
行人归期_judge_04=庚格:年=>年格,年内可归
行人归期_judge_05=!庚格=>无庚格,行人不归
行人归期_judge_06=xingren?旺=>行人旺相,路途顺利
行人归期_judge_07=xingren?囚=>行人休囚,路途困顿
行人归期_judge_08=xingren?空=>行人空亡,音信全无
行人归期_judge_09=xingren!jiaren=>行人克家人,归则生事
行人归期_judge_10=jiaren!xingren=>家人克行人,行人在外受制

# --- 求财 (卷八) ---
# 以甲子戊(值符)为财神,生门为财方
求财_label=求财
求财_source=卷八
求财_role_caishen=ref:值符
求财_role_caifang=gate:生门
求财_judge_01=caishen?奇+caishen?吉格+caifang?奇+caifang?吉格=>财神财方俱得奇门吉格,所求如意得财多
求财_judge_02=caifang?奇+caifang?吉格=>财方得奇门吉格,得财
求财_judge_03=caishen?奇=>得奇不得门,得之不多
求财_judge_04=caifang?吉门=>得门不得奇,得之不多
求财_judge_05=caishen?空+caifang?空=>财神财方俱落空亡,必不得财反招是非
求财_judge_06=caishen?空=>财神空亡,求财无望
求财_judge_07=caifang?空=>财方空亡,无财可得
求财_judge_08=caishen?墓=>财神入墓,求财受阻
求财_judge_09=caifang?墓=>财方入墓,财路堵塞
求财_judge_10=caifang?内=>财方在内四宫,求财近且易得
求财_judge_11=caifang?外=>财方在外四宫,求财远须奔走

# --- 贸易 (卷八) ---
# 以甲子戊(值符)为资本,生门为利息
贸易_label=贸易
贸易_source=卷八
贸易_role_ziben=ref:值符
贸易_role_lixi=gate:生门
贸易_judge_01=lixi?奇+lixi?吉格+lixi>ziben=>生门得奇吉格生值符,必获倍利
贸易_judge_02=lixi>ziben=>生门生值符,有利润
贸易_judge_03=lixi=ziben=>比和,得中利
贸易_judge_04=ziben>lixi=>值符生生门,加添资本仍得利息
贸易_judge_05=lixi!ziben+lixi?凶格=>生门克值符乘凶格,必折本
贸易_judge_06=lixi?墓+lixi?凶格=>生门落墓乘凶格,必耗尽资本大凶
贸易_judge_07=lixi?空=>生门空亡,无利可图

# --- 合伙求财 (卷八) ---
# 以日干为我,时干为合计(合伙人)
合伙求财_label=合伙求财
合伙求财_source=卷八
合伙求财_role_wo=ref:日干
合伙求财_role_biren=ref:时干
合伙求财_judge_01=biren?奇+biren?吉格+biren>wo=>合伙人得奇吉格生我,合计有益于我
合伙求财_judge_02=wo?奇+wo?吉格+wo>biren=>我得奇吉格生彼,有益于他
合伙求财_judge_03=wo=biren=>比和,合伙公平各无猜忌
合伙求财_judge_04=biren!wo+biren?凶格=>合伙人克我乘凶格,不利于我
合伙求财_judge_05=wo!biren=>我克彼,彼有损失
合伙求财_judge_06=biren?空=>合伙人空亡,合伙不成

# --- 开店 (卷八) ---
# 以开门主之
开店_label=开店
开店_source=卷八
开店_role_dianpu=gate:开门
开店_role_rigan=ref:日干
