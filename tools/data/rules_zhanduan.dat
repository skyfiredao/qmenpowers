用药_judge_04=yao?空=>天心空亡,无药可用
用药_judge_05=xiao?空=>生门空亡,用药无效
用药_judge_06=yao?旺+xiao?旺=>药与效俱旺,用药速愈
用药_judge_07=yao?囚=>天心休囚,药效不佳

# --- 家宅 (卷十一) ---
# 以生门为宅,天柱为堂柱,日干为宅主
家宅_label=家宅
家宅_source=卷十一
家宅_role_zhai=gate:生门
家宅_role_tangzhu=star:天柱
家宅_role_zhaizhu=ref:日干
家宅_judge_01=zhai?旺+zhai?奇+zhai?吉格=>生门旺相得奇吉格,宅运大吉
家宅_judge_02=zhai>zhaizhu=>生门生日干,居之吉利
家宅_judge_03=zhai!zhaizhu=>生门克日干,居之不利
家宅_judge_04=zhai?囚+zhai?凶格=>生门休囚凶格,宅运衰败
家宅_judge_05=zhai?空=>生门空亡,此宅空虚不旺
家宅_judge_06=tangzhu?囚=>天柱休囚,房屋破损
家宅_judge_07=tangzhu?墓=>天柱入墓,宅基不安
家宅_judge_08=zhai@zhaizhu=>生门与日干同宫,人宅合一大吉

# --- 坟墓 (卷十一) ---
# 以死门为坟,天柱为碑,日干为后人
坟墓_label=坟墓
坟墓_source=卷十一
坟墓_role_fen=gate:死门
坟墓_role_bei=star:天柱
坟墓_role_houren=ref:日干
坟墓_judge_01=fen?旺+fen?奇=>死门旺相得奇,祖坟安妥荫后
坟墓_judge_02=fen>houren=>死门生日干,祖坟荫庇后人
坟墓_judge_03=fen!houren=>死门克日干,祖坟妨后人
坟墓_judge_04=fen?囚+fen?凶格=>死门休囚凶格,坟墓损坏
坟墓_judge_05=fen?空=>死门空亡,坟墓不安
坟墓_judge_06=fen?墓=>死门入墓,坟地不佳
坟墓_judge_07=bei?囚=>天柱休囚,碑石残缺

# --- 出行 (卷十一) ---
# 以开门为行,值符为行人,时干为目的地
出行_label=出行
出行_source=卷十一
出行_role_xingmen=gate:开门
出行_role_xingren=ref:值符
出行_role_mudi=ref:时干
出行_judge_01=xingmen?旺+xingmen?奇+xingmen?吉格=>开门旺相得奇吉格,出行大吉
出行_judge_02=xingmen>xingren=>开门生值符,路途顺利
出行_judge_03=mudi>xingren=>时干生值符,到达有益
出行_judge_04=xingmen?凶格+xingmen?囚=>开门休囚凶格,出行不利
出行_judge_05=xingmen?空=>开门空亡,不宜出行
出行_judge_06=xingren?空=>值符空亡,人不宜动
出行_judge_07=mudi!xingren=>时干克值符,目的地不利
出行_judge_08=mudi?凶门+mudi?凶格=>目的地凶门凶格,到达有碍

# --- 求学 (卷十一) ---
# 以天辅为学业,景门为文采,日干为学子
求学_label=求学
求学_source=卷十一
求学_role_xueye=star:天辅
求学_role_wencai=gate:景门
求学_role_xuezi=ref:日干
求学_judge_01=xueye?旺+xueye?奇+wencai?旺=>天辅旺相得奇景门旺相,学业有成
求学_judge_02=xueye>xuezi=>天辅生日干,学业顺遂
求学_judge_03=xueye?旺=>天辅旺相,学业进步
求学_judge_04=xueye?囚=>天辅休囚,学业不振
求学_judge_05=wencai?空=>景门空亡,文思枯涩
求学_judge_06=xueye?墓=>天辅入墓,学业受阻
求学_judge_07=wencai?旺+wencai?奇=>景门旺相得奇,文采卓著

# --- 怀孕 (卷十二) ---
# 以天芮为胎,六合为子
怀孕_label=怀孕
怀孕_source=卷十二
怀孕_role_tai=star:天芮
怀孕_role_zi=deity:六合
怀孕_role_mu=ref:日干
怀孕_judge_01=tai?旺+zi?旺=>胎星子神俱旺,必有胎且安
怀孕_judge_02=tai?空=>天芮空亡,无胎
怀孕_judge_03=zi?空=>六合空亡,子息难得
怀孕_judge_04=tai?旺+zi?囚=>有胎但子弱
怀孕_judge_05=tai?囚+zi?旺=>胎弱子旺,妊娠辛苦但终得子
怀孕_judge_06=tai?墓=>天芮入墓,堕胎之虑
怀孕_judge_07=mu?旺+tai?旺=>母旺胎旺,母子平安

# --- 天气 (卷十三) ---
# 以天蓬为雨,天英为晴,景门为晴
天气_label=天气
天气_source=卷十三
天气_role_yushen=star:天蓬
天气_role_qingshen=star:天英
天气_role_jingmen=gate:景门
天气_judge_01=yushen?旺=>天蓬旺相,主有雨
天气_judge_02=qingshen?旺+jingmen?旺=>天英景门俱旺,主晴
天气_judge_03=yushen?囚+qingshen?旺=>天蓬休囚天英旺,必晴
天气_judge_04=yushen?旺+qingshen?囚=>天蓬旺天英囚,必雨
天气_judge_05=yushen?空=>天蓬空亡,虽阴不雨
天气_judge_06=qingshen?空=>天英空亡,难得晴天
天气_judge_07=jingmen?空=>景门空亡,阴晦不明

# --- 农事 (卷十三) ---
# 以天任为田土,生门为收成
农事_label=农事
农事_source=卷十三
农事_role_tiantu=star:天任
农事_role_shoucheng=gate:生门
农事_judge_01=tiantu?旺+shoucheng?旺=>天任生门俱旺,五谷丰登
农事_judge_02=tiantu?旺+shoucheng?囚=>田土旺收成弱,劳多得少
农事_judge_03=tiantu?囚+shoucheng?旺=>田土囚收成旺,不种而获
农事_judge_04=tiantu?囚+shoucheng?囚=>俱休囚,收成不佳
农事_judge_05=tiantu?空=>天任空亡,田地荒芜
农事_judge_06=shoucheng?空=>生门空亡,颗粒无收
农事_judge_07=tiantu?墓=>天任入墓,田土有碍

# --- 逃亡 (卷十) ---
# 以逃者时干为主,开门为出路
逃亡_label=逃亡
逃亡_source=卷十
逃亡_role_taozhe=ref:时干
逃亡_role_chulu=gate:开门
逃亡_judge_01=taozhe?旺+chulu?旺+chulu?奇=>逃者旺出路得奇,必逃脱
逃亡_judge_02=taozhe?旺+chulu?旺=>逃者旺出路旺,可逃
逃亡_judge_03=taozhe?囚=>逃者休囚,不能逃脱
逃亡_judge_04=chulu?空=>开门空亡,无路可逃
逃亡_judge_05=taozhe?空=>逃者空亡,人已不在
逃亡_judge_06=taozhe?墓=>逃者入墓,被擒
逃亡_judge_07=庚格:时=>时格,即时被捕
逃亡_judge_08=庚格:日=>日格,当日被捕
逃亡_judge_09=!庚格=>无庚格,久不获

# --- 寻人 (卷十) ---
# 以六合为所寻之人,日干为寻人者
寻人_label=寻人
寻人_source=卷十
寻人_role_suoxun=deity:六合
寻人_role_xunren=ref:日干
寻人_judge_01=suoxun?内+xunren?内=>彼此俱在内,近处可寻
寻人_judge_02=suoxun?外=>所寻之人在外,远处难寻
寻人_judge_03=suoxun>xunren=>所寻之人生日干,彼愿相见
寻人_judge_04=suoxun!xunren=>所寻之人克日干,彼不愿见
寻人_judge_05=suoxun?空=>六合空亡,其人已远去
寻人_judge_06=suoxun?墓=>六合入墓,其人隐匿不出
寻人_judge_07=庚格:日=>日格,当日可见
寻人_judge_08=庚格:月=>月格,当月可见
寻人_judge_09=!庚格=>无庚格,寻之不得
